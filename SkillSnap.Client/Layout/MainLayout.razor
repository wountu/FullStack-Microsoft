@namespace SkillSnap.Client.Layout
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="page">
    <header>
       <nav class="navbar w-100 fixed-top" style="height:60px; background-color:black; padding:0 10px;">
            <div class="d-flex w-100 justify-content-between align-items-center">
                <ul class="navbar-nav flex-row">
                    <li class="nav-item me-3">
                        <NavLink class="nav-link text-white" href="/">Traders</NavLink>
                    </li>
                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item me-3">
                                <NavLink class="nav-link text-white" href="myprofiles">Profiles</NavLink>
                            </li>
                        </Authorized>
                    </AuthorizeView>
                </ul>

                <ul class="navbar-nav flex-row">
                    <AuthorizeView>
                        <Authorized>
                            <li class="nav-item me-3">
                                <NavLink class="nav-link text-white" href="logout">Logout</NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link text-white" href="register">Register</NavLink>
                            </li>
                        </Authorized>

                        <NotAuthorized>
                            <li class="nav-item me-3">
                                <NavLink class="nav-link text-white" href="login">Login</NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link text-white" href="register">Register</NavLink>
                            </li>
                        </NotAuthorized>
                    </AuthorizeView>
                </ul>
            </div>
        </nav>
    </header>

    <main style="margin-top:60px; padding:20px;">
        @Body
    </main>
</div>

